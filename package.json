{
  "devDependencies": {
    "@codyswann/lisa": "^2.142.1",
    "eslint-plugin-oxlint": "^1.62.0",
    "oxlint": "^1.62.0",
    "oxlint-tsgolint": "^0.22.1"
  },
  "scripts": {
    "build": "tsc",
    "postinstall": "[ -n \"$CI\" ] || node node_modules/@codyswann/lisa/dist/index.js --yes --skip-git-check . 2>/dev/null || true",
    "test:integration": "vitest run tests/integration --passWithNoTests",
    "test": "vitest run",
    "setup:deploy-key": "setup-deploy-key",
    "lint": "oxlint && eslint . --quiet",
    "format:check": "prettier --check .",
    "format": "prettier --check . --write",
    "test:unit": "vitest run --exclude='**/integration/**'",
    "test:cov": "vitest run --coverage",
    "test:watch": "vitest",
    "lint:fix": "oxlint --fix && eslint . --fix",
    "lint:slow": "eslint . --config eslint.slow.config.ts --quiet",
    "typecheck": "tsc --noEmit",
    "knip": "knip",
    "knip:fix": "knip --fix",
    "sg:scan": "ast-grep scan",
    "prepare": "node -e \"if (process.env.INIT_CWD && process.env.INIT_CWD.includes('.serverless')) { process.exit(0); }\" && husky install || true"
  },
  "engines": {
    "npm": "please-use-bun",
    "yarn": "please-use-bun",
    "pnpm": "please-use-bun",
    "bun": "1.3.8",
    "node": "22.21.1"
  },
  "name": "aws-setup",
  "version": "1.0.0",
  "description": "[![License: MIT](https://img.shields.io/badge/License-MIT-yellow.svg)](https://opensource.org/licenses/MIT) [![SOC 2 Compliant](https://img.shields.io/badge/SOC%202-Compliant-green)](https://www.aicpa.org/interestareas/frc/assuranceadvisoryservices/soc2relevantguidance.html) [![AWS Control Tower](https://img.shields.io/badge/AWS-Control%20Tower-orange)](https://aws.amazon.com/controltower/)",
  "license": "ISC",
  "author": "",
  "type": "commonjs",
  "main": "index.js",
  "trustedDependencies": [
    "@ast-grep/cli",
    "@codyswann/lisa",
    "@sentry/cli"
  ],
  "resolutions": {
    "@isaacs/brace-expansion": "^5.0.1",
    "axios": ">=1.15.2",
    "handlebars": ">=4.7.9"
  },
  "overrides": {
    "@isaacs/brace-expansion": "^5.0.1",
    "axios": ">=1.15.2",
    "handlebars": ">=4.7.9"
  }
}
